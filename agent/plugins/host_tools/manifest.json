{
  "id": "com.claudez.plugins.host-tools",
  "name": "主机工具链",
  "version": "2.1.0",
  "author": "ClaudeZ Team",
  "description": "自动探测本机开发工具链并挂载为 Agent 可调用工具 — 探明即挂载，屏蔽可恢复",
  "category": "utility",
  "icon": "🖥️",
  "probes": [
    {"name":"node",     "category":"command",   "icon":"🔵", "display_name":"Node.js",   "exec_name":"node",    "version_args":["--version"], "version_regex":"v?(\\d+\\.\\d+\\.\\d+)"},
    {"name":"npm",      "category":"package",   "icon":"📦", "display_name":"npm",       "exec_name":"npm",     "version_args":["--version"], "version_regex":"(\\d+\\.\\d+\\.\\d+)"},
    {"name":"python",   "category":"command",   "icon":"🐍", "display_name":"Python",    "exec_name":"python",  "version_args":["--version"], "version_regex":"Python (\\d+\\.\\d+\\.\\d+)"},
    {"name":"pip",      "category":"package",   "icon":"📦", "display_name":"pip",       "exec_name":"pip",     "version_args":["--version"], "version_regex":"pip (\\d+\\.\\d+\\.\\d+)"},
    {"name":"git",      "category":"vcs",       "icon":"🔗", "display_name":"Git",       "exec_name":"git",     "version_args":["--version"], "version_regex":"git version (\\d+\\.\\d+\\.\\d+)"},
    {"name":"docker",   "category":"container", "icon":"🐳", "display_name":"Docker",    "exec_name":"docker",  "version_args":["--version"], "version_regex":"Docker version (\\d+\\.\\d+\\.\\d+)"},
    {"name":"go",       "category":"compiler",  "icon":"🔷", "display_name":"Go",        "exec_name":"go",      "version_args":["version"],   "version_regex":"go(\\d+\\.\\d+\\.\\d+)"},
    {"name":"rustc",    "category":"compiler",  "icon":"🦀", "display_name":"Rust",      "exec_name":"rustc",   "version_args":["--version"], "version_regex":"rustc (\\d+\\.\\d+\\.\\d+)"},
    {"name":"java",     "category":"command",   "icon":"☕", "display_name":"Java",      "exec_name":"java",    "version_args":["-version"],  "version_regex":"(\\d+\\.\\d+\\.\\d+)"},
    {"name":"curl",     "category":"network",   "icon":"🔗", "display_name":"curl",      "exec_name":"curl",    "version_args":["--version"], "version_regex":"curl (\\d+\\.\\d+\\.\\d+)"},
    {"name":"dotnet",   "category":"compiler",  "icon":"🟣", "display_name":".NET",      "exec_name":"dotnet",  "version_args":["--version"], "version_regex":"(\\d+\\.\\d+\\.\\d+)"},
    {"name":"cargo",    "category":"package",   "icon":"🦀", "display_name":"Cargo",     "exec_name":"cargo",   "version_args":["--version"], "version_regex":"cargo (\\d+\\.\\d+\\.\\d+)"},
    {"name":"flutter",  "category":"command",   "icon":"💙", "display_name":"Flutter",   "exec_name":"flutter", "version_args":["--version"], "version_regex":"Flutter (\\d+\\.\\d+\\.\\d+)"},
    {"name":"dart",     "category":"compiler",  "icon":"🎯", "display_name":"Dart",      "exec_name":"dart",    "version_args":["--version"], "version_regex":"Dart (\\d+\\.\\d+\\.\\d+)"},
    {"name":"cordova",  "category":"command",   "icon":"📱", "display_name":"Cordova",   "exec_name":"cordova", "version_args":["--version"], "version_regex":"(\\d+\\.\\d+\\.\\d+)"},
    {"name":"gradle",   "category":"build",     "icon":"🛠️","display_name":"Gradle",    "exec_name":"gradle",  "version_args":["--version"], "version_regex":"Gradle (\\d+\\.\\d+)"},
    {"name":"adb",      "category":"command",   "icon":"📱", "display_name":"ADB",       "exec_name":"adb",     "version_args":["--version"], "version_regex":"(\\d+\\.\\d+\\.\\d+)"},
    {"name":"aapt2",    "category":"build",     "icon":"📦", "display_name":"AAPT2",     "exec_name":"aapt2",   "version_args":["version"],   "version_regex":"\\d+"},
    {"name":"apksigner","category":"build",     "icon":"🔏", "display_name":"apksigner", "exec_name":"apksigner","version_args":["--version"],"version_regex":"(\\d+\\.\\d+)"},
    {"name":"zipalign", "category":"build",     "icon":"🔧", "display_name":"zipalign",  "exec_name":"zipalign","version_args":["--version"],"version_regex":"\\d+"},
    {"name":"sdkmanager","category":"package",  "icon":"📦", "display_name":"sdkmanager","exec_name":"sdkmanager","version_args":["--version"],"version_regex":"(\\d+\\.\\d+\\.\\d+)"},
    {"name":"avdmanager","category":"system",   "icon":"📱", "display_name":"avdmanager","exec_name":"avdmanager","version_args":["--version"],"version_regex":"(\\d+\\.\\d+\\.\\d+)"},
    {"name":"jarsigner", "category":"build",    "icon":"🔏", "display_name":"jarsigner", "exec_name":"jarsigner","version_args":["-version"],  "version_regex":"(\\d+\\.\\d+\\.\\d+)"},
    {"name":"keytool",   "category":"build",    "icon":"🔑", "display_name":"keytool",   "exec_name":"keytool",  "version_args":["-version"],  "version_regex":"(\\d+\\.\\d+\\.\\d+)"}
  ]
}
